# PostgreSQL — format: postgresql://USER:PASS@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://postgres:Admin66@@55@@@localhost:5432/blacktree?schema=public"

PORT=5000
NODE_ENV=development

# JWT — replace with a long random string in production
JWT_SECRET=change-me-to-a-very-long-random-secret-string-in-production
JWT_EXPIRES_IN=7d

# CORS — must match your Vite dev server origin
CLIENT_URL=http://localhost:5173
