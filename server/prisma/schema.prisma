// BlackTree.TV — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  avatar    String?
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Movie {
  id          String   @id @default(uuid())
  title       String
  description String?
  poster      String
  backdrop    String?
  category    String   @default("vod")   // vod | featured | trending
  genre       String?
  year        Int?
  duration    Int?
  rating      Float?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("movies")
}

model Actor {
  id          String  @id @default(uuid())
  name        String
  bio         String?
  image       String
  nationality String?
  createdAt   DateTime @default(now())

  @@map("actors")
}

model Episode {
  id          String   @id @default(uuid())
  title       String
  description String?
  thumbnail   String
  scheduledAt DateTime
  endsAt      DateTime
  status      String   @default("scheduled") // live | scheduled | ended
  isLive      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("episodes")
}

model Interview {
  id          String   @id @default(uuid())
  label       String
  name        String
  tagline     String
  description String
  image       String
  videoUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("interviews")
}

model ChatMessage {
  id        String   @id @default(uuid())
  user      String
  avatar    String?
  message   String
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

model MovieRequest {
  id        String   @id @default(uuid())
  movieName String
  votes     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("movie_requests")
}
