// ============================================================
// subscriber.prisma
// Model: Subscriber
// Tracks newsletter and marketing mailing list signups.
// ============================================================

model Subscriber {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  // Linking to User if they decide to register later
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  status SubscriberStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([userId])
}
