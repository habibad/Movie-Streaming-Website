// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id          String   @id @default(uuid())
  title       String
  description String?
  poster      String   // URL
  backdrop    String?
  category    String   // "vod" | "featured" | "trending"
  genre       String?
  year        Int?
  duration    Int?     // minutes
  rating      Float?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  actors      Actor[]

}

model Actor {
  id    String  @id @default(uuid())
  name  String
  bio   String?
  image String  // URL
  movieId String 
  movie   Movie @relation(fields: [movieId], references: [id])
}

model Episode {
  id          String    @id @default(uuid())
  title       String
  description String?
  thumbnail   String
  scheduledAt DateTime
  endsAt      DateTime
  status      String    @default("scheduled") // "live" | "scheduled" | "ended"
  isLive      Boolean   @default(false)
}

model Interview {
  id          String  @id @default(uuid())
  label       String
  name        String
  tagline     String
  description String
  image       String
  videoUrl    String?
}

model ChatMessage {
  id        String   @id @default(uuid())
  user      String
  avatar    String?
  message   String
  createdAt DateTime @default(now())
}
